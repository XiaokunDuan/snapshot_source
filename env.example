# Google Gemini API Key Pool
# 将所有的 API 密钥用逗号分隔，系统会随机选择一个使用
GEMINI_API_KEY_POOL=your_gemini_api_key_1,your_gemini_api_key_2
GEMINI_MODEL=gemini-2.5-flash
TEXT_API_BASE_URL=https://v2.aicodee.com/v1
TEXT_API_KEY=your_text_api_key
TEXT_MODEL=MiniMax-M2.5-highspeed

# Cloudflare R2 Storage Configuration
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Neon PostgreSQL Database
# Get this from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/vocabulary?sslmode=require

# Optional MCP enrichment
MCP_WIKI_ENABLED=false
BRAVE_API_KEY=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# CDN domain for uploaded files (used in server-side upload API)
# The R2 bucket name is currently hardcoded in app/api/upload/route.ts as word-app-images
CDN_PUBLIC_BASE_URL=https://snapshot.yulu34.top
